generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id           String    @id @default(cuid())
  alias              String    // nome breve (es. "VILLA SOSPISIO")
  businessName       String?   // ragione sociale (es. "MIRO' SRL")
  iban               String?
  vatNumber          String?   // partita IVA
  email              String?
  phone              String?   // telefono fisso
  mobile             String?   // cellulare
  contactPerson      String?   // referente/i (es. "Mario Rossi, Laura Bianchi")
  serviceSummary     String?   // sintesi servizio (es. "DINNER 19.06")
  serviceDescription String?   // descrizione estesa del servizio
  notes              String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  costs      Cost[]
  payments   Payment[]
  documents  Document[]
  extraCosts ExtraCost[]
}

model Cost {
  id         String  @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amountNet  Float   // importo netto
  vatRate    Float?  // aliquota IVA (es. 10, 22)
  vatAmount  Float?  // importo IVA
  totalGross Float?  // totale ivato
  notes      String?
  createdAt  DateTime @default(now())
}

model Payment {
  id         String        @id @default(cuid())
  supplierId String
  supplier   Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type       PaymentType   // ACCONTO o SALDO
  label      String?       // etichetta tranche (es. "Acconto 1", "Tranche 2", "Saldo finale")
  amount     Float
  dueDate    DateTime?     // scadenza
  paidDate   DateTime?     // data effettivo pagamento
  status     PaymentStatus @default(PENDING)
  invoiceRef String?       // riferimento fattura/preventivo
  causale    String?       // causale per bonifico
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Document {
  id         String       @id @default(cuid())
  supplierId String?
  supplier   Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  type       DocumentType
  number     String?      // numero fattura/preventivo
  fileName   String
  filePath   String
  mimeType   String?
  rawText    String?      // testo estratto dal documento
  parsedData Json?        // dati strutturati estratti dall'AI
  createdAt  DateTime     @default(now())
}

model ExtraCost {
  id               String          @id @default(cuid())
  supplierId       String
  supplier         Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  description      String          // descrizione della spesa extra
  amount           Float           // importo
  status           ExtraCostStatus @default(DA_CONFERMARE)
  addToPaymentPlan Boolean         @default(false) // se true, va nel piano pagamenti; se false, pagamento a parte
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum ExtraCostStatus {
  DA_CONFERMARE
  CONFERMATA
}

enum PaymentType {
  ACCONTO
  SALDO
}

enum PaymentStatus {
  PENDING   // da pagare
  SCHEDULED // programmato
  PAID      // pagato
  OVERDUE   // scaduto
}

enum DocumentType {
  PREVENTIVO
  FATTURA
  CONTRATTO
  RICEVUTA
  ALTRO
}

// ==========================================
// GUEST MANAGEMENT
// ==========================================

model Guest {
  id                  String    @id @default(cuid())
  firstName           String
  lastName            String
  fullName            String?
  email               String?
  phone               String?
  phoneOffice         String?
  mailingAddress      String?
  city                String?
  state               String?
  zip                 String?

  // Hotel
  hotelRoomsNeeded    Int?
  roomType            String?
  checkInDate         DateTime?
  checkOutDate        DateTime?
  hotelUpgrade        String?

  // Passport
  passportCountry     String?
  passportNumber      String?
  passportExpiry      String?
  dateOfBirth         String?

  // Dietary & Medical
  dietaryRestrictions String?
  mobilityNeeds       String?
  medicalInfo         String?
  healthAttestation   Boolean   @default(false)

  // Assistant
  assistantName       String?
  assistantEmail      String?
  assistantPhone      String?

  // Emergency contact
  emergencyName       String?
  emergencyPhone      String?
  emergencyEmail      String?
  emergencyRelation   String?

  // Transport
  noTransfer          Boolean   @default(false)

  // Meal attendance: JSON object with keys like "17giu_cena", "18giu_pranzo", "18giu_cena", etc.
  // Values are booleans. Null = all meals attended (default assumption)
  mealAttendance      Json?

  // Bio & misc
  bio                 String?
  whatsappOptIn       Boolean   @default(false)
  specialRequests     String?
  notes               String?

  // Privacy & consent preferences
  privacyConsent      Boolean   @default(false)
  imageRightsConsent  Boolean   @default(false)
  liabilityConsent    Boolean   @default(false)
  cancellationConsent Boolean   @default(false)
  insuranceConsent    Boolean   @default(false)

  companions          GuestCompanion[]
  flights             GuestFlight[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model GuestCompanion {
  id           String  @id @default(cuid())
  guestId      String
  guest        Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  fullName     String
  relationship String?
  notes        String?
  createdAt    DateTime @default(now())
}

model GuestFlight {
  id               String    @id @default(cuid())
  guestId          String
  guest            Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  direction        FlightDirection
  departureAirport String?
  arrivalAirport   String?
  airline          String?
  flightNumber     String?
  date             DateTime?
  departureTime    String?
  arrivalDay       DateTime?
  arrivalTime      String?
  notes            String?
  createdAt        DateTime  @default(now())
}

model GuestImport {
  id         String   @id @default(cuid())
  fileName   String
  fileType   String   // EXCEL, PDF
  status     ImportStatus @default(PENDING)
  data       Json?    // parsed preview data
  errors     Json?    // parsing errors
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum FlightDirection {
  ARRIVAL
  DEPARTURE
}

enum ImportStatus {
  PENDING
  REVIEWED
  CONFIRMED
  REJECTED
}
